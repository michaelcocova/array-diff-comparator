{
  "name": "array-diff-comparator",
  "version": "0.0.1-beta.1",
  "description": "High-performance JSON object array diff tool with unique key matching, field comparison, conflict detection and resolution.",
  "homepage": "https://github.com/michaelcocova/array-diff-comparator#readme",
  "bugs": {
    "url": "https://github.com/michaelcocova/array-diff-comparator/issues"
  },
  "license": "MIT",
  "author": "Author Name <author.name@mail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michaelcocova/array-diff-comparator.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "bump": "bumpp --no-push --no-commit --no-tag",
    "changelog": "node ./scripts/generate-changelog.mjs",
    "release:dry": "pnpm publish --access public --registry https://registry.npmjs.org/ --dry-run --no-git-checks",
    "prepublishOnly": "vp run build",
    "prepare": "vp config",
    "docs:dev": "vitepress dev",
    "docs:build": "vitepress build",
    "docs:preview": "vitepress preview",
    "build:docs": "vitepress build"
  },
  "dependencies": {
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "oxc-minify": "^0.91.0",
    "typescript": "^6.0.3",
    "unplugin-unused": "^0.5.7",
    "vite-plus": "^0.1.20",
    "vitepress": "2.0.0-alpha.17"
  },
  "packageManager": "pnpm@11.3.0"
}
